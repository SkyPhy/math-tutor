# ── Secrets & local data (NEVER commit) ───────────────────────────────────
# API keys / gateway config. The real keys live ONLY in backend/.env, which is
# created from backend/.env.example by each developer (see README "Setup").
backend/.env
math-tutor-demo/backend/.env
.env
.env.local

# Persistent data — user accounts/password hashes + exam bank (SQLite)
backend/data/
math-tutor-demo/backend/data/
*.db
*.sqlite
*.sqlite3

# Full local project backups (backup #2) — never upload
backup/

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# ── Node (frontend tooling) ────────────────────────────────────────────────
node_modules/
dist/

# ── OS / editor noise ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
