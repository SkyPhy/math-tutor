# ── Claude (Anthropic-compatible gateway) ─────────────────────────────────
# Copy this file to `.env` and fill in the real values. `.env` is read at
# startup by config.py. Never commit `.env`.

# Base URL of your gateway (NO trailing slash, NO /v1 — the client appends
# /v1/messages itself). Example: https://your-gateway.example.com
CLAUDE_BASE_URL=

# Your API key for the gateway.
CLAUDE_API_KEY=

# Auth header style: "x-api-key" (Anthropic standard) or "authorization"
# (sends `Authorization: Bearer <key>`). Default: x-api-key
CLAUDE_AUTH_HEADER=x-api-key

# Anthropic API version header the gateway expects.
CLAUDE_ANTHROPIC_VERSION=2023-06-01

# Models shown in the UI dropdown, comma-separated as `id|Label`.
# Replace the ids with the EXACT strings your gateway accepts.
CLAUDE_MODELS=claude-opus-4-8|Opus 4.8,claude-opus-4-6|Opus 4.6,claude-sonnet-4-6|Sonnet 4.6

# Which model id is selected first.
CLAUDE_DEFAULT_MODEL=claude-opus-4-8

# ── Optional behaviour knobs (sane defaults if omitted) ────────────────────
CLAUDE_TIMEOUT=30
CLAUDE_MAX_TOKENS=1024
CLAUDE_TEMPERATURE=0.4
CLAUDE_BREAKER_THRESHOLD=3
CLAUDE_BREAKER_COOLDOWN=60
CLAUDE_RATE_PER_HOUR=60

# ══════════════════════════════════════════════════════════════════════════
#  MULTI-PROVIDER LLMs — DeepSeek / GPT (OpenAI-compatible) beside Claude
# ══════════════════════════════════════════════════════════════════════════
# The tutor can generate questions, grade answers, and answer help chats with
# ANY of these providers. Claude uses the Anthropic protocol above; DeepSeek and
# GPT use the OpenAI Chat Completions protocol. A provider with a blank
# BASE_URL/API_KEY is simply "not usable" and its models never appear — so you can
# enable just the ones you have keys for. Model ids must be EXACTLY what the
# provider/gateway accepts.

# ── DeepSeek (OpenAI-compatible) ───────────────────────────────────────────
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODELS=deepseek-chat|DeepSeek Chat,deepseek-reasoner|DeepSeek Reasoner

# ── OpenAI / GPT (OpenAI-compatible) ───────────────────────────────────────
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=
OPENAI_MODELS=gpt-4o|GPT-4o,gpt-4o-mini|GPT-4o mini

# ── ADMIN control of the student model pool (两者结合) ──────────────────────
# WHICH models a STUDENT may pick is ADMIN-controlled, NOT student-controlled.
#   • ADMIN_USERNAMES — accounts (comma-separated) granted the "admin" role; ONLY
#     they may toggle model availability / force a model (POST /admin/models,
#     gated by require_admin). Seeded at sign-up and on every startup. Students
#     can never reach these controls. Leave blank if you don't need runtime admin.
#   • LLM_FORCED_MODEL — optional .env-level "强制分配": force ALL students onto
#     this one model id. Blank = students choose freely within the enabled pool.
#     (Admins can also set/clear this at runtime; the runtime value wins.)
# See docs/MODELS_AND_PROVIDERS.md — the enable/force switch is ADMIN-ONLY.
ADMIN_USERNAMES=
LLM_FORCED_MODEL=

# ── Handwriting OCR — nex-n2-pro (OpenAI-compatible vision) ────────────────
# Separate endpoint + key from Claude. The whiteboard image is sent to
# {NEX_OCR_BASE_URL}/v1/chat/completions as an image_url; the model transcribes
# the math. *** FILL THESE IN to enable real OCR. *** Until then /recognize
# returns a mock expression.

# Base URL of the OCR gateway (with or without a trailing /v1; the client adds
# /chat/completions). Example: https://your-ocr-gateway.example.com
NEX_OCR_BASE_URL=

# Your OCR API key (sent as `Authorization: Bearer <key>`).
NEX_OCR_API_KEY=

# Vision model id.
NEX_OCR_MODEL=nex-n2-pro

# Optional knobs. nex-n2-pro is a reasoning model — keep MAX_TOKENS generous or
# it spends the whole budget "thinking" and returns empty content. The gateway
# can be slow/congested, so the timeout is generous; raise it if you see
# frequent "recogniser timed out" messages.
NEX_OCR_TIMEOUT=90
NEX_OCR_MAX_TOKENS=1500

# ── Handwriting OCR — DeepSeek (OpenAI-compatible VISION) ──────────────────
# A THIRD OCR engine (method=deepseek). The whiteboard image is sent to
# {DEEPSEEK_OCR_BASE_URL}/v1/chat/completions as an image_url. The model MUST be
# multimodal/vision-capable — a text-only DeepSeek model cannot read images.
# Base URL / key default to the DeepSeek chat settings above if left blank.
DEEPSEEK_OCR_BASE_URL=
DEEPSEEK_OCR_API_KEY=
DEEPSEEK_OCR_MODEL=deepseek-vl
DEEPSEEK_OCR_TIMEOUT=90
DEEPSEEK_OCR_MAX_TOKENS=1500
